# --- Database Credentials (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=security_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# --- Threat Intelligence API Keys ---
VIRUSTOTAL_API_KEY=your_vt_key
GREYNOISE_API_KEY=your_greynoise_key
OTX_API_KEY=your_otx_key

# --- Gemini API for crewAI Agents ---
GEMINI_API_KEY=AIzaSy...

# --- Windows Remediation (WinRM) ---
WINRM_USER=administrator
WINRM_PASSWORD=your_secure_password
WINRM_TRANSPORT=ntlm

# macOS SSH Credentials for Remediation
MACOS_SSH_USER=admin
MACOS_SSH_KEY_PATH=/path/to/your/id_rsa
# MACOS_SSH_PASSPHRASE=your_key_passphrase (optional)

# Ubuntu SSH Credentials for Remediation
UBUNTU_SSH_USER=ubuntu
UBUNTU_SSH_KEY_PATH=/path/to/your/id_rsa

# Kali Linux (Offensive Security Sub-Agent)
KALI_SSH_HOST=192.168.1.100
KALI_SSH_USER=kali
KALI_SSH_KEY_PATH=/path/to/kali_id_rsa
# KALI_SSH_PASSPHRASE=optional_passphrase
